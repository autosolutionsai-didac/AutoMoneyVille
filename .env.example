# Claudeville environment configuration (OPS-2)
# Copy to `.env` for local dev (start.sh auto-sources it) or export these in your
# deployment. `.env` is gitignored — never commit real secrets.

# --- Django frontend (environment/frontend_server) ---

# Secret key. The previously-committed dev key was rotated out and is considered
# compromised. Generate a fresh one for any non-local environment, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-generate-a-real-key

# Debug mode. MUST be True for local `runserver` to serve static assets
# (the Phaser map, sprites, and CSS). Keep False in production.
DJANGO_DEBUG=True

# Comma-separated allowed hosts. Required (non-empty) when DJANGO_DEBUG=False.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# --- Backend proxy target (environment/frontend_server/translator/views.py) ---
# Where the Django frontend proxies API calls (the Flask backend).
CLAUDEVILLE_BACKEND_URL=http://127.0.0.1:5000

# --- Simulation backend (reverie/backend_server) ---
# Per-persona timeout (seconds) for a single LLM move. Default 90 (the full
# 10-person roster runs ~10 concurrent calls; the cold day-planning window is slow).
# Lower it for snappier (lossier) play; the timeout fallback is benign (full rollback).
CLAUDEVILLE_PERSONA_MOVE_TIMEOUT=90

# --- Real web search for agent research (tool_executor.py) ---
# When set, web_research/market_analysis return LIVE results fed into agent memory;
# unset (or on any error) they return an honest "no live search" stub (no fabrication).
# Provider: "firecrawl" (default) or "exa" (extensible to tavily/serper/brave). Put the
# REAL key in .env only (gitignored) — NEVER here.
CLAUDEVILLE_SEARCH_BACKEND=firecrawl
CLAUDEVILLE_SEARCH_API_KEY=your-firecrawl-api-key-here

# --- P2 A2 Tiered Model Routing (claude_structure.py) ---
# Enables routing routine ticks to cheaper/faster models while keeping high-quality
# models for decisions and reflections. When unset, falls back to CLAUDEVILLE_CLAUDE_MODEL.
# Use Haiku-class for FAST, Sonnet-class for MAIN, Opus-class (or Sonnet) for REFLECT.
# Example (adjust to your available models):
# CLAUDEVILLE_MODEL_FAST=claude-haiku-4-5-20251001
# CLAUDEVILLE_MODEL_MAIN=claude-sonnet-4-6
# CLAUDEVILLE_MODEL_REFLECT=claude-opus-4-8
# The main override (still supported):
# CLAUDEVILLE_CLAUDE_MODEL=claude-sonnet-4-6
