# Local configuration
local_config.json
frontend_server/settings/local.py

# Claude Code / Agent
.claude/
CLAUDE.md

# IDE
.vscode/

# Storage - ignore runs, keep base templates
environment/frontend_server/storage/runs/*
!environment/frontend_server/storage/runs/.gitkeep

# Compressed storage - generated output, ignore all
environment/frontend_server/compressed_storage/*
!environment/frontend_server/compressed_storage/.gitkeep

# Temp storage - all runtime files ignored (created on first run)
environment/frontend_server/temp_storage/*
!environment/frontend_server/temp_storage/.gitkeep

static_dirs/*

bin/
include/
pip-selfcheck.json
.DS_Store

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

